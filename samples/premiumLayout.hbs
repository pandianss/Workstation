<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4;
            margin: 20mm;
        }
        
        @font-face {
            font-family: 'ArimaTamil';
            src: url('data:font/ttf;base64,{{organization.tamilFont}}') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        @font-face {
            font-family: 'NotoHindi';
            src: url('data:font/ttf;base64,{{organization.hindiFont}}') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        body { 
            font-family: 'Century Gothic', 'Segoe UI', Tahoma, sans-serif; 
            margin: 0;
            padding: 0;
            background-color: white;
            color: #1a202c;
            line-height: 1.6;
            font-size: 18px; 
        }

        .page-container {
            width: 100%;
            position: relative;
        }

        /* Indic Font Classes */
        .tamil-text, .bank-name-ta, .tamil-col, .sig-trilingual {
            font-family: 'ArimaTamil', sans-serif !important;
        }
        .hindi-text, .bank-name-hi, .hindi-col {
            font-family: 'NotoHindi', sans-serif !important;
        }

        /* Header Layout */
        .header {
            display: flex;
            align-items: center;
            border-bottom: 2px solid #00338d;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .logo-container {
            width: 80px; /* Slightly larger logo */
            margin-right: 20px;
        }

        .logo-img {
            max-width: 100%;
            height: auto;
        }

        .bank-names-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 8px; /* Increased spacing to avoid 'imposing' look */
        }

        .bank-name-ta {
            color: #00338d;
            font-size: 20px; 
            font-weight: 800;
            line-height: 1.2;
        }

        .bank-name-hi {
            color: #00338d;
            font-size: 17px; 
            font-weight: 600;
            line-height: 1.1;
        }

        .bank-name-en {
            color: #00338d;
            font-size: 18px; 
            font-weight: 800;
            text-transform: uppercase;
            font-family: Arial, sans-serif;
            line-height: 1.1;
            letter-spacing: 0.8px;
        }

        /* 3-Column Info Section */
        .info-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            text-align: center;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 12px;
        }

        .info-col {
            flex: 1;
        }

        .info-label {
            font-size: 11px;
            font-weight: 800;
            color: #00338d;
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .info-value {
            font-size: 13.5px;
            font-weight: 600;
            color: #1a202c;
        }

        .contact-bar {
            background-color: #f1f5f9;
            padding: 6px 15px;
            display: flex;
            justify-content: center;
            gap: 30px;
            font-size: 11px;
            color: #475569;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        /* Table Hardening */
        table {
            page-break-inside: auto;
            width: 100%;
            border-collapse: collapse;
        }
        
        thead {
            display: table-header-group; /* Ensures header repeats on each page */
        }
        
        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        th {
            background-color: #00338d !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
        }
        /* 3-Column Info Section */
        .info-section {
            display: flex;
            justify-content: space-between;
            align-items: stretch; /* Ensures all columns have the same height */
            margin-top: 15px;
            padding: 10px 0;
            /* border-top removed for clean look */
        }
        .info-col {
            flex: 1;
            padding: 0 5px;
            font-size: 10px;
            color: #444;
            border-right: 1px solid #ddd;
            text-align: center;
            overflow-wrap: break-word;
        }
        .info-col:last-child {
            border-right: none;
        }
        .tamil-col {
            font-size: 6.5pt;
            flex: 1; /* Match other columns for alignment */
        }
        .office-label {
            font-weight: 800;
            display: block;
            margin-bottom: 4px;
            color: #1a1a1a;
            font-size: 10.5px;
        }
        .tamil-col .office-label {
            font-size: 7.5pt;
            font-weight: 900; /* Maximum boldness for small title */
        }
        .tamil-col .address-text {
            line-height: 1.2;
        }
        .address-text {
            line-height: 1.3;
        }

        /* Contact Section */
        .contact-section {
            background: #eef4ff; /* Pale blue box */
            padding: 7px 0;
            font-size: 10px;
            color: #444;
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-bottom: 20px;
            border-radius: 2px;
        }

        .meta-strip {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 25px;
            color: #222;
            padding-bottom: 4px;
        }

        .content { 
            min-height: 520px; 
            position: relative;
            z-index: 1;
        }
        
        .doc-title {
            text-align: center;
            margin-bottom: 25px;
        }
        .doc-title h2, .main-title { 
            font-size: 16px; 
            color: #00338d; 
            text-decoration: none;
            text-transform: uppercase;
            margin: 0;
            letter-spacing: 0.5px;
            font-weight: 800;
        }
        .doc-subtitle {
            font-size: 12px;
            color: #444;
            margin-top: 4px;
            font-weight: 700;
        }
        .meta-header {
            font-size: 9px;
            color: #666;
            margin-top: 3px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1px;
        }

        .letter-body {
            font-size: 14.5px;
            text-align: justify;
        }

        .footer { 
            margin-top: 50px; 
            padding-top: 15px;
        }
        
        .signatories-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
            margin-top: 20px;
        }
        
        .signatory-col {
            flex: 1;
            text-align: center;
            min-width: 0;
        }
        
        .signature-space {
            height: 35px;
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            padding-bottom: 5px;
        }
        
        .sig-line {
            color: #cbd5e1;
            margin-bottom: 8px;
            letter-spacing: -1px;
        }

        .sig-trilingual {
            font-size: 11.5px;
            font-weight: 900;
            color: #334155;
            margin-bottom: 2px;
            font-family: 'ArimaTamil', 'NotoHindi', sans-serif !important;
        }

        .sig-name-en {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            color: #1e293b;
            margin-bottom: 1px;
        }

        .sig-title-en {
            font-size: 10px;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.2px;
        }
        
        .page-footer {
            position: absolute;
            bottom: 15px;
            left: 50px;
            right: 50px;
            font-size: 9px;
            color: #aaa;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="page-container">
        <!-- Centered Header with Logo -->
        <div class="header">
            <div class="logo-container">
                {{#if organization.bankLogo}}
                <img src="{{organization.bankLogo}}" class="logo-img" alt="IOB Logo">
                {{/if}}
            </div>
            <div class="bank-names-container">
                <div class="bank-name-ta">{{organization.bankNameTa}}</div>
                <div class="bank-name-hi">{{organization.bankNameHi}}</div>
                <div class="bank-name-en">{{organization.bankNameEn}}</div>
            </div>
        </div>

        <!-- 3-Column Info Row -->
        <div class="info-section">
            <div class="info-col tamil-col">
                <span class="office-label">{{organization.officeNameTa}}</span>
                <div class="address-text">{{{organization.addressTaFormatted}}}</div>
            </div>
            <div class="info-col hindi-col">
                <span class="office-label">{{organization.officeNameHi}}</span>
                <div class="address-text">{{{organization.addressHiFormatted}}}</div>
            </div>
            <div class="info-col">
                <span class="office-label">{{organization.officeNameEn}}</span>
                <div class="address-text">{{{organization.addressEnFormatted}}}</div>
            </div>
        </div>

        <!-- Contact Row -->
        <div class="contact-section">
            <span><strong>Phone:</strong> {{organization.phone}}</span>
            <span><strong>Email:</strong> {{organization.email}}</span>
            <span><strong>Web:</strong> {{organization.website}}</span>
        </div>

        <!-- Meta Strip -->
        <div class="meta-strip">
            <span>Ref No: {{refNo}}</span>
            <span>Date: {{date}}</span>
        </div>

        <div class="content">
            <div class="doc-title">
                <h2 class="main-title">
                    {{#if titleTa}}<span class="tamil-text">{{titleTa}}</span> / {{/if}}
                    {{#if titleHi}}<span>{{titleHi}}</span> / {{/if}}
                    <span>{{title}}</span>
                </h2>
                {{#if subTitle}}
                <div class="doc-subtitle">
                    {{#if subTitleTa}}<span class="tamil-text">{{subTitleTa}}</span> / {{/if}}
                    {{#if subTitleHi}}<span>{{subTitleHi}}</span> / {{/if}}
                    <span>{{subTitle}}</span>
                </div>
                {{/if}}
                {{#if metaHeader}}
                <div class="meta-header">{{metaHeader}}</div>
                {{/if}}
            </div>

            <div class="letter-body">
                {{{bodyHtml}}}
            </div>
        </div>

        <!-- Footer / Signatories -->
        <div class="footer">
            {{#if initiator}}
            <div class="signatory-row initiator-row">
                <div class="signatory-col" style="text-align: right;">
                    <div class="signature-space">Sd/-</div>
                    <div class="sig-line">-------------------------------------</div>
                    <div class="sig-trilingual">
                        {{#if initiator.nameTa}}({{initiator.nameTa}}) / {{/if}}
                        {{#if initiator.nameHi}}({{initiator.nameHi}}){{/if}}
                    </div>
                    <div class="sig-name-en">({{initiator.nameEn}})</div>
                    <div class="sig-title-en">{{initiator.titleEn}}</div>
                </div>
            </div>
            {{/if}}

            {{#if reviewersOrApprovers}}
            <div class="signatories-row">
                {{#each reviewersOrApprovers}}
                <div class="signatory-col">
                    <div class="signature-space">Sd/-</div>
                    <div class="sig-line">-------------------------------------</div>
                    <div class="sig-trilingual">
                        {{#if nameTa}}({{nameTa}}) / {{/if}}
                        {{#if nameHi}}({{nameHi}}){{/if}}
                    </div>
                    <div class="sig-name-en">({{nameEn}})</div>
                    <div class="sig-title-en">{{titleEn}}</div>
                </div>
                {{/each}}
            </div>
            {{/if}}

            <div class="seal-container" style="margin-top: 30px;">
                {{#if deptSealSrc}}
                    <img src="{{deptSealSrc}}" class="seal-img" style="max-height: 80px; opacity: 0.8;" alt="Seal">
                {{/if}}
            </div>
        </div>

        <div class="page-footer">
            Generated by Dindigul Banking Portal | Confidential
        </div>
    </div>
</body>
</html>
