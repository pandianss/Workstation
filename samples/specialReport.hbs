                        <line x1="1720" y1="0"    x2="1820" y2="100"/>
                        <line x1="1760" y1="0"    x2="1820" y2="60"/>
                        <line x1="1800" y1="0"    x2="1820" y2="20"/>
                        <line x1="1640" y1="0"    x2="1820" y2="180"/>
                        <line x1="1600" y1="0"    x2="1820" y2="220"/>
                        <line x1="1820" y1="60"   x2="1660" y2="220"/>
                        <line x1="1820" y1="120"  x2="1620" y2="320"/>
                        <line x1="1820" y1="200"  x2="1580" y2="440"/>
                    </g>

                    <g fill="#1e293b" opacity="0.055">
                        <circle cx="55"  cy="490" r="9"/>
                        <circle cx="115" cy="490" r="9"/>
                        <circle cx="175" cy="490" r="9"/>
                        <circle cx="55"  cy="550" r="9"/>
                        <circle cx="115" cy="550" r="9"/>
                        <circle cx="175" cy="550" r="9"/>
                        <circle cx="85"  cy="520" r="6"/>
                        <circle cx="145" cy="520" r="6"/>
                    </g>

                    <rect x="25" y="455" width="230" height="140" rx="10"
                          fill="none" stroke="#1e293b" stroke-width="2" opacity="0.045"
                          transform="rotate(-5 140 525)"/>
                    <rect x="50" y="475" width="160" height="100" rx="7"
                          fill="none" stroke="#1e293b" stroke-width="1.2" opacity="0.03"
                          transform="rotate(-5 130 525)"/>

                </svg>
            </div>

            <h2 class="metric-title" id="metric-title-{{@index}}">{{label}}</h2>

            <div class="ranking-container">

                <div class="ranking-list" role="list" aria-label="Top 10 performers for {{label}}">
                    <h3 class="top-h4">↗ Top 10</h3>

                    {{#each data.top}}
                    <div class="rank-item" role="listitem">
                        <div class="rank-num top-num" aria-label="Rank {{add @index 1}}">
                            {{add @index 1}}
                        </div>
                        <div class="branch-info">
                            <span class="branch-name" title="{{name}}">{{name}}</span>
                            <div class="progress-bar" role="presentation">
                                <div class="progress-fill progress-fill-top"
                                     style="width: {{percent}}%;"
                                     aria-hidden="true"></div>
                            </div>
                        </div>
                        <div class="branch-val" aria-label="Value: {{value}}">{{{formattedValue}}}</div>
                    </div>
                    {{/each}}
                </div>

                <div class="ranking-list" role="list" aria-label="Bottom 10 performers for {{label}}">
                    <h3 class="bottom-h4">▼ Bottom 10</h3>

                    {{#each data.bottom}}
                    <div class="rank-item" role="listitem">
                        <div class="rank-num bot-num" aria-label="Rank {{add @index 1}}">
                            {{add @index 1}}
                        </div>
                        <div class="branch-info">
                            <span class="branch-name" title="{{name}}">{{name}}</span>
                            <div class="progress-bar" role="presentation">
                                <div class="progress-fill progress-fill-bot"
                                     style="width: {{percent}}%;"
                                     aria-hidden="true"></div>
                            </div>
                        </div>
                        <div class="branch-val" aria-label="Value: {{value}}">{{{formattedValue}}}</div>
                    </div>
                    {{/each}}
                </div>

            </div>
        </section>
        {{/each}}
    </main>

</body>
</html>
