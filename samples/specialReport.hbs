<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <!--
        REPORT TEMPLATE — IOB Dindigul Region
        ─────────────────────────────────────────────────────────────────
        Renderer:  Handlebars (or compatible)
        Output:    Fixed 1920 × 3216px — exclusively for PDF/image export
        ─────────────────────────────────────────────────────────────────
        Required custom Handlebars helpers:
          • {{add a b}}          — returns a + b  (used for 1-based rank index)
          • {{{formattedValue}}} — triple-mustache intentional; value may
                                   contain safe HTML (e.g. <br>, <strong>).
                                   IMPORTANT: always sanitize upstream before
                                   passing into this template to prevent XSS.
        ─────────────────────────────────────────────────────────────────
    -->

    <style>
        /* ── Web fonts ─────────────────────────────────────────────── */
        @font-face {
            font-family: 'Inter';
            src: url('data:font/truetype;base64,{{fonts.regular}}') format('truetype');
            font-weight: 400;
            font-display: block;
        }
        @font-face {
            font-family: 'Inter';
            src: url('data:font/truetype;base64,{{fonts.bold}}') format('truetype');
            font-weight: 700;
            font-display: block;
        }

        /* ── Design tokens ─────────────────────────────────────────── */
        :root {
            --navy:          #1e293b;
            --navy-light:    #334155;
            --teal:          #0d9488;
            --teal-soft:     #f0fdf4;
            --gold:          #ca8a04;
            --red:           #be123c;
            --red-soft:      #fef2f2;
            --border:        #e2e8f0;
            --muted:         #64748b;
            --surface:       #f8fafc;
            --surface-deep:  #f1f5f9;

            --gap-sm:  30px;
            --gap-md:  50px;
            --gap-lg:  60px;
            --gap-xl:  80px;

            --text-md:   32px;
            --text-lg:   44px;
            --text-xl:   56px;
            --text-2xl:  64px;
            --text-3xl:  72px;
        }

        /* ── Reset ──────────────────────────────────────────────────── */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ── Page shell ─────────────────────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            background: #ffffff;
            color: var(--navy);
            width: 1920px;
            height: 3216px;
            padding: 40px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative; /* anchor for .page-watermark */
        }

        /* ══════════════════════════════════════════════════════════════
           WATERMARKS
           All watermark layers sit below all content via z-index.
           pointer-events: none prevents any interference with PDF clicks.
        ══════════════════════════════════════════════════════════════ */

        .page-watermark {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        /* Per-card watermark — absolutely positioned inside .metric-section */
        .card-watermark {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
            border-radius: inherit;
        }

        /* Lift all real content above watermarks */
        .header,
        .metrics-grid {
            position: relative;
            z-index: 1;
        }

        /* ── Header ─────────────────────────────────────────────────── */
        .header {
            flex-shrink: 0;
            padding-bottom: 20px;
            margin-bottom: var(--gap-md);
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: var(--gap-sm);
        }

        .logo img {
            height: 120px;
            width: auto;
            display: block;
        }

        .logo:empty { height: 120px; }

        .ro-badge {
            background: var(--gold);
            color: #ffffff;
            padding: 24px 48px;
            border-radius: 16px;
            font-size: var(--text-md);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            white-space: nowrap;
        }

        .header-main h1 {
            font-size: var(--text-2xl);
            font-weight: 900;
            text-transform: uppercase;
            color: var(--navy);
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .header-period {
            font-size: var(--text-md);
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header-period::before {
            content: '';
            flex-shrink: 0;
            display: inline-block;
            width: 50px;
            height: 6px;
            background: var(--gold);
            border-radius: 3px;
        }

        .header-generated {
            margin-left: auto;
            font-size: 24px;
            opacity: 0.7;
            font-weight: 400;
        }

        /* ── Metrics grid ───────────────────────────────────────────── */
        .metrics-grid {
            display: flex;
            flex-direction: column;
            flex: 1;
            gap: var(--gap-xl);
            min-height: 0;
        }

        /* ── Metric section card ────────────────────────────────────── */
        .metric-section {
            position: relative; /* anchor for .card-watermark */
            background: var(--surface);
            border-radius: 40px;
            padding: 45px 50px;
            border: 2px solid var(--border);
            flex: 1;
            min-height: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* clip card watermark to rounded corners */
        }

        .metric-title {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: var(--gap-sm);
            font-size: var(--text-3xl);
            font-weight: 900;
            text-transform: uppercase;
            color: var(--navy);
            border-bottom: 8px solid var(--border);
            padding-bottom: var(--gap-sm);
            margin-bottom: var(--gap-lg);
            line-height: 1;
            position: relative;
            z-index: 1;
        }

        /* ── Ranking columns ────────────────────────────────────────── */
        .ranking-container {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: var(--gap-lg);
            flex: 1;
            min-height: 0;
            position: relative;
            z-index: 1;
        }

        .ranking-list {
            display: flex;
            flex-direction: column;
        }

        .ranking-list h3 {
            flex-shrink: 0;
            font-size: var(--text-2xl); /* Increased from xl to 2xl (64px) */
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 40px;
            display: inline-flex;
            align-items: center;
            gap: 20px;
            white-space: nowrap;
            line-height: 1;
            padding: 15px 35px;
            border-radius: 16px;
        }

        .top-h4    { color: var(--teal); background: var(--teal-soft); }
        .bottom-h4 { color: var(--red);  background: var(--red-soft); }

        .ranking-list + .ranking-list {
            border-left: 3px solid var(--border);
            padding-left: var(--gap-lg);
        }

        /* ── Rank row ───────────────────────────────────────────────── */
        .rank-item {
            display: flex;
            align-items: center;
            gap: 20px;
            flex: 1;
            min-height: 0;
            padding: 6px 0;
        }

        .rank-num {
            flex-shrink: 0;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--text-lg);
            font-weight: 900;
            background: var(--surface-deep);
            color: var(--muted);
        }

        /* ── Podium Styling (Top 10 Only) ─────────────────────────── */
        .ranking-list:first-child .rank-item:nth-of-type(1) .rank-num { background: #ca8a04; color: white; }
        .ranking-list:first-child .rank-item:nth-of-type(2) .rank-num { background: #cbd5e1; color: var(--navy); }
        .ranking-list:first-child .rank-item:nth-of-type(3) .rank-num { background: #ea580c; color: white; }

        .bot-num { background: var(--red-soft);  color: var(--red);  }

        .branch-info {
            flex: 1;
            min-width: 0;
            max-width: calc(100% - 380px);
        }

        .branch-name {
            font-size: var(--text-xl);
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 12px;
            display: block;
        }

        .progress-bar {
            height: 28px;
            background: var(--surface-deep);
            border-radius: 14px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 14px;
            will-change: width;
        }

        .progress-fill-top { background: var(--teal); }
        .progress-fill-bot { background: var(--red);  }

        .branch-val {
            flex-shrink: 0;
            width: 320px;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            justify-content: center;
            text-align: right;
            color: var(--navy);
            font-size: var(--text-xl);
            font-weight: 700;
        }

    </style>
</head>
<body>

