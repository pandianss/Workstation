    <!-- ── Header ──────────────────────────────────────────────────── -->
    <header class="header">
        <div class="header-top">
            <div class="logo" aria-label="IOB Logo">
                {{#if logoSrc}}
                <img src="{{logoSrc}}" alt="Indian Overseas Bank" />
                {{/if}}
            </div>
            <div class="ro-badge" aria-label="Region">Dindigul Region</div>
        </div>

        <div class="header-main">
            <h1>Performance Analytics — Special Report</h1>
            <p class="header-period">
                <span>{{periodLabel}}</span>
                <span aria-hidden="true" style="opacity: 0.4;">|</span>
                <span>{{dateRange}}</span>
                <span class="header-generated">Generated: {{generatedAt}}</span>
            </p>
        </div>
    </header>

    <!-- ── Metrics ─────────────────────────────────────────────────── -->
    <main class="metrics-grid">
        {{#each metrics}}
        <section class="metric-section" aria-labelledby="metric-title-{{@index}}">

            <div class="card-watermark" aria-hidden="true">
                <svg width="100%" height="100%" preserveAspectRatio="xMaxYMin meet"
                     viewBox="0 0 1820 620" xmlns="http://www.w3.org/2000/svg"
                     aria-hidden="true">

                    <g fill="none" stroke="#0d9488" stroke-linecap="round">
                        <path d="M 1820 0 A  180  180 0 0 0 1640  180" stroke-width="3.0" opacity="0.11"/>
